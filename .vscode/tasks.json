{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "start-arize",
      "type": "shell",
      "command": "${workspaceFolder}/backend/.venv/bin/python",
      "args": ["-m", "phoenix.server.main", "serve"],
      "isBackground": true,
      "problemMatcher": {
        "pattern": [
          {
            "regexp": ".*",
            "file": 0,
            "message": 0,
            "line": 0
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "."
        }
      }
    }
  ]
}
